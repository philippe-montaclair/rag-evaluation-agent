{
  "uid": "rageval-main",
  "title": "RagEval — Qualité & Performance",
  "tags": ["rageval", "rag", "llm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Qualité — scores RAGAS (dernière éval)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        { "refId": "A", "expr": "rag_faithfulness", "legendFormat": "faithfulness", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rag_answer_relevancy", "legendFormat": "answer_relevancy", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "rag_context_precision", "legendFormat": "context_precision", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "D", "expr": "rag_context_recall", "legendFormat": "context_recall", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Fidélité (faithfulness)",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rag_faithfulness", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Performance (dernier appel)",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "latence (ms)" }, "properties": [ { "id": "unit", "value": "ms" } ] }
        ]
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "rag_latency_ms", "legendFormat": "latence (ms)", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rag_tokens_total", "legendFormat": "tokens total", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Qualité dans le temps (par éval poussée)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rag_faithfulness", "legendFormat": "faithfulness", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rag_answer_relevancy", "legendFormat": "answer_relevancy", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "rag_context_precision", "legendFormat": "context_precision", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "D", "expr": "rag_context_recall", "legendFormat": "context_recall", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence & tokens dans le temps",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "latence (ms)" }, "properties": [ { "id": "unit", "value": "ms" } ] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "rag_latency_ms", "legendFormat": "latence (ms)", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rag_tokens_total", "legendFormat": "tokens total", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
